# --- Payload ---
PAYLOAD_SECRET=replace-with-long-random-string
# Postgres connection string. Use a different Neon database than the
# fulfillment platform to keep their data isolated.
DATABASE_URI=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
NEXT_PUBLIC_SERVER_URL=http://localhost:3001

# --- Artbox fulfillment platform connection ---
FULFILLMENT_API_URL=http://localhost:3000
FULFILLMENT_API_KEY=

# --- Artist brand ---
NEXT_PUBLIC_ARTIST_NAME=Vincent van Gogh
NEXT_PUBLIC_ARTIST_TAGLINE=Studies in light and colour
NEXT_PUBLIC_BRAND_PRIMARY=#1a1a1a
NEXT_PUBLIC_BRAND_ACCENT=#a86232
NEXT_PUBLIC_BRAND_BG=#fafaf6
